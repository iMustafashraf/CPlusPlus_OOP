#include <iostream>
#include <string>
#include <fstream>

using namespace std;

class Phone {
private:
	string phoneNumber;
	string type;
public:

	Phone(string ph = "00000", string tp = "Unkown") {
		phoneNumber = ph;
		type = tp;
	};

	void Setphone(string ph) {
		bool got_wrong = false;

		if(ph.size() <= 5) got_wrong = true;

		for (int i = 0; i < ph.size(); i++) {
			if (ph[i] < 48 || ph[i] > 57 || got_wrong) {
				got_wrong = true;
				break;
			}
		}

		if (got_wrong) {
			cout << "The number is wrong, the current Details :\n";
		}else {
			phoneNumber = ph;
		}
	}
	void Settype(string tp) {
		type = tp;
	}

	string Getphone() {
		return phoneNumber;
	}
	string Gettype() {
		return type;
	}

	void Display() {
		cout << "Phone number = " << phoneNumber << ", and its type = " << type << endl;
	}
};

class User {
private:
	int id;
	string name;
	Phone phone[3];
	int phoneCount;
public:

	User(int ID = 01111, string nm = "unknown") {
		id = ID;
		name = nm;
		phoneCount = 0;
	}

	void Setname(string nm) {
		name = nm;
	}
	string Getname() {
		return name;
	}

	void Setid(int d) {
		id = d;
	}
	int Getid() {
		return id;
	}

	void addPhone(Phone p) {
		if (phoneCount < 3) {
			phone[phoneCount] = p;
			phoneCount++;
		}
	}
	void printUserInfo() {
		cout << "-------------{ New State }----------\n";
		cout << "User name : " << name << ", and ID : " << id << endl;
		for (int i = 0; i < phoneCount; i++) {
			phone[i].Display();
		}
		
	}
};

